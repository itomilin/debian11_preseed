################################ POSTINST ######################################
d-i preseed/late_command string \

#   Download post_cmd.sh script.
    in-target /bin/sh -c "curl -sL \
        https://raw.githubusercontent.com/itomilin/debian11_preseed/main/post_cmd.sh \
        -o /root/post_cmd.sh && chmod +x /root/post_cmd.sh"; \
    in-target /bin/bash -c "/root/post_cmd.sh 'debian'";
################################################################################


################################ ENDDO #########################################
d-i finish-install/reboot_in_progress      note

d-i cdrom-detect/eject             boolean true
d-i debian-installer/exit/halt     boolean false
d-i debian-installer/exit/poweroff boolean false
