################################################################################


################################ PATRTITIONING #################################
# Force UEFI installation.
d-i partman-efi/non_efi_system boolean true

d-i partman-basicfilesystems/choose_label  string gpt
d-i partman-basicfilesystems/default_label string gpt
d-i partman-partitioning/choose_label      string gpt
d-i partman-partitioning/default_label     string gpt
d-i partman/choose_label                   string gpt
d-i partman/default_label                  string gpt

# SET FIRST DRIVE
d-i partman/early_command string              \
    BOOT_DEV=$(list-devices disk | head -1) ; \
    debconf-set partman-auto/disk $BOOT_DEV

# EXT4
d-i partman-auto/method string regular
# LVM
#d-i partman-auto/method string lvm
# Remove old lvm partitioning.
#d-i partman-lvm/device_remove_lvm boolean true

d-i partman-auto/choose_recipe select atomic
d-i partman-auto/expert_recipe string \
    512   30  512      fat32          \
        $primary{ }                   \
        $reusemethod{ }               \
        $iflabel{ gpt }               \
        method{ efi }                 \
        format{ }                     \
    . \
    51200 30  51200    ext4           \
        $primary{ }                   \
        label{ root }                 \
        method{ format }              \
        format{ }                     \
        use_filesystem{ }             \
        filesystem{ ext4 }            \
        options/noatime{ noatime }    \
        options/discard{ discard }    \
        mountpoint{ / }               \
    . \
    100   100 -1       ext4           \
        $primary{ }                   \
        label{ home }                 \
        method{ format }              \
        format{ }                     \
        use_filesystem{ }             \
        filesystem{ ext4 }            \
        options/noatime{ noatime }    \
        options/discard{ discard }    \
        mountpoint{ /home }           \
    .

# Auto confirm uncomment to apply it.
d-i partman-partitioning/confirm_write_new_label boolean true
d-i partman/choose_partition                     select  finish
d-i partman/confirm                              boolean true
d-i partman/confirm_nooverwrite                  boolean true

# Skip question about not having swap partition.
partman-basicfilesystems partman-basicfilesystems/no_swap boolean false
################################################################################


################################ SOURCES #######################################
d-i apt-setup/non-free boolean true
d-i apt-setup/contrib  boolean true

d-i apt-setup/use_mirror      boolean true
#d-i apt-setup/services-select multiselect security, updates
d-i apt-setup/services-select multiselect updates

d-i apt-setup/security_host                string  security.debian.org
d-i debian-installer/allow_unauthenticated boolean false
################################################################################


################################ ADDITIONAL ####################################
# BASE UTILITIES
tasksel tasksel/first multiselect standard, ssh-server

# BASE PACKAGES
d-i pkgsel/include string  aptitude rsync vim git curl pcregrep \
                           firmware-linux-free firmware-amd-graphics \
                           firmware-intel-sound firmware-misc-nonfree \
                           firmware-realtek firmware-linux firmware-linux-nonfree \
                           intel-media-va-driver gcc make linux-headers-amd64 \
                           linux-cpupower

d-i popularity-contest/participate boolean false
d-i pkgsel/upgrade                 select  full-upgrade
